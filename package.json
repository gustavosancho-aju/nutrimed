{
  "name": "nutrimed",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "pnpm --filter @nutrimed/web dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "format": "prettier --check \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.0"
  }
}
